# ── Base de données PostgreSQL (Neon.tech) ───────────────────────────────────
# URL poolée (pour les requêtes Vercel serverless)
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
# URL directe (pour les migrations Prisma)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://ton-domaine.com"
NEXTAUTH_SECRET="genere-avec-openssl-rand-base64-32"

# ── Images — Cloudinary (gratuit 25GB) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME="ton-cloud-name"
CLOUDINARY_UPLOAD_PRESET="guard-conciergerie-preset"

# ── Site ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://ton-domaine.com"
NEXT_PUBLIC_SITE_NAME="Guard Conciergerie Luxury Care"

# ── Email (optionnel) ─────────────────────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
NOTIFICATION_EMAIL=""
